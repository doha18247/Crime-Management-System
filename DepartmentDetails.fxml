                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Label alignment="CENTER" layoutX="420.0" layoutY="214.0" prefHeight="25.0" prefWidth="280.0" text="Cases" textAlignment="CENTER" textFill="#0d2c54">
               <font>
                  <Font name="System Bold" size="18.0" />
