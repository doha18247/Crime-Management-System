   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="800.0" spacing="10.0" style="-fx-background-color: #0D2C54; -fx-padding: 5; -fx-border-color: #6A1017; -fx-border-width: 5;" BorderPane.alignment="CENTER">
