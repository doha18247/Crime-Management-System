<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<BorderPane prefWidth="800.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="LoginCon">
   <center>
      <AnchorPane fx:id="anchorPane" prefHeight="600.0" prefWidth="800.0" style="-fx-border-color: #6A1017; -fx-border-width: 0 5 5 5; -fx-background-color: #F5F5F5;">
         <children>
            <ImageView fx:id="MOI" fitHeight="150.0" fitWidth="150.0" layoutX="15.0" layoutY="15.0" pickOnBounds="true" preserveRatio="true" />
            <ImageView fx:id="FCIS" fitHeight="150.0" fitWidth="150.0" layoutX="635.0" layoutY="15.0" pickOnBounds="true" preserveRatio="true" />
            <Pane layoutX="170.0" layoutY="164.0" prefHeight="340.0" prefWidth="460.0" style="-fx-background-color: #0D2C54; -fx-border-color: #6A1017; -fx-border-width: 10;">
               <children>
                  <Label alignment="CENTER" layoutX="40.0" layoutY="40.0" prefHeight="70.0" prefWidth="380.0" style="-fx-background-color: #f5f5f5; -fx-border-color: #6A1017; -fx-border-width: 5;" text="Insert Username and password" textAlignment="CENTER" textFill="#0d2c54" wrapText="true">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <TextField fx:id="username" alignment="CENTER" layoutX="30.0" layoutY="120.0" onAction="#Authenticate" prefHeight="50.0" prefWidth="400.0" promptText="Enter username" style="-fx-background-color: #F5F5F5; -fx-text-fill: #0D2C54; -fx-border-color: #6A1017; -fx-border-width: 5;">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </TextField>
                  <PasswordField fx:id="password" alignment="CENTER" layoutX="30.0" layoutY="180.0" onAction="#Authenticate" prefHeight="50.0" prefWidth="400.0" promptText="Enter password" style="-fx-background-color: #F5F5F5; -fx-text-inner-color: #0D2C54; -fx-border-color: #6A1017; -fx-border-width: 5;">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </PasswordField>
                  <Button fx:id="loginBtn" alignment="CENTER" layoutX="155.0" layoutY="240.0" mnemonicParsing="false" onAction="#Authenticate" prefHeight="50.0" prefWidth="150.0" style="-fx-background-color: #F5F5F5; -fx-border-color: #6A1017; -fx-border-width: 5;" text="Login" textFill="#0d2c54">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Button>
               </children>
            </Pane>
         </children>
      </AnchorPane>
   </center>
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="800.0" spacing="10.0" style="-fx-background-color: #0D2C54; -fx-padding: 5; -fx-border-color: #6A1017; -fx-border-width: 5;" BorderPane.alignment="CENTER">
         <children>
            <Label prefHeight="20.0" prefWidth="710.0" text="Crime Management System" textFill="WHITESMOKE">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <Button fx:id="minimzeBtn" mnemonicParsing="false" onAction="#titleBar" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #F5F5F5;" text="-" textFill="#0d2c54">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
            <Button fx:id="closeBtn" mnemonicParsing="false" onAction="#titleBar" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #6A1017;" text="X" textFill="WHITESMOKE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </top>
</BorderPane>
