<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CasesPageCon">
   <center>
      <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #F5F5F5; -fx-border-color: #6A1017; -fx-border-width: 0 5 5 5;">
         <children>
            <Label alignment="CENTER" layoutY="21.0" prefHeight="17.0" prefWidth="800.0" text="Cases" textFill="#0d2c54">
               <font>
                  <Font name="System Bold" size="36.0" />
               </font>
            </Label>
            <Label layoutX="73.0" layoutY="83.0" prefHeight="55.0" prefWidth="693.0" style="-fx-background-color: #0D2C54; -fx-border-color: #6A1017; -fx-border-width: 3; -fx-padding: 0 10 0 10;" text="Search By ID" textFill="WHITESMOKE">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <TextField fx:id="search" layoutX="201.0" layoutY="88.0" onAction="#search" prefHeight="45.0" prefWidth="550.0" style="-fx-text-fill: #0D2C54; -fx-font-weight: bold; -fx-background-color: #F5F5F5; -fx-border-color: #6A1017; -fx-border-width: 2;">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </TextField>
            <Button fx:id="back" layoutX="9.0" layoutY="83.0" mnemonicParsing="false" onAction="#Back" prefHeight="55.0" prefWidth="60.0" style="-fx-border-color: #6A1017; -fx-background-color: #0D2C54; -fx-border-width: 3;" text="Back" textFill="WHITESMOKE">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Button>
            <ScrollPane hbarPolicy="NEVER" layoutX="10.0" layoutY="150.0">
               <content>
                  <FlowPane fx:id="cases" hgap="5.0" prefHeight="400.0" prefWidth="770.0" prefWrapLength="800.0" rowValignment="TOP" style="-fx-padding: 10; -fx-background-color: #0D2C54; -fx-border-color: #6A1017; -fx-border-width: 2;" vgap="5.0" />
               </content>
            </ScrollPane>
         </children>
      </AnchorPane>
   </center>
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="800.0" spacing="10.0" style="-fx-background-color: #0D2C54; -fx-padding: 5; -fx-border-color: #6A1017; -fx-border-width: 5;" BorderPane.alignment="CENTER">
         <children>
            <Label prefHeight="20.0" prefWidth="710.0" text="Crime Management System" textFill="WHITESMOKE">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <Button fx:id="minimzeBtn" mnemonicParsing="false" onAction="#titleBar" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #F5F5F5;" text="-" textFill="#0d2c54">
