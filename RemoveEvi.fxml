<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="RemoveEviCon">
   <center>
      <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #F5F5F5; -fx-border-color: #6A1017; -fx-border-width: 0 5 5 5;">
         <children>
            <Label alignment="CENTER" layoutY="21.0" prefHeight="17.0" prefWidth="800.0" text="Remove Evidence" textFill="#0d2c54">
               <font>
                  <Font name="System Bold" size="36.0" />
               </font>
            </Label>
            <Button fx:id="back" layoutX="9.0" layoutY="75.0" mnemonicParsing="false" onAction="#Back" prefHeight="36.0" prefWidth="60.0" style="-fx-border-color: #6A1017; -fx-background-color: #0D2C54; -fx-border-width: 3;" text="Back" textFill="WHITESMOKE">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Button>
            <AnchorPane layoutX="10.0" layoutY="125.0" prefHeight="400.0" prefWidth="780.0" style="-fx-background-color: #F5F5F5; -fx-border-color: #0D2C54; -fx-border-width: 10;">
               <children>
                  <Button fx:id="remove" alignment="CENTER" layoutX="653.0" layoutY="319.0" mnemonicParsing="false" onAction="#Remove" prefHeight="61.0" prefWidth="107.0" style="-fx-border-color: #6A1017; -fx-background-color: #0D2C54; -fx-border-width: 3;" text="Remove" textAlignment="CENTER" textFill="WHITESMOKE" wrapText="true">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                  <Label layoutX="14.0" layoutY="20.0" prefHeight="27.0" prefWidth="197.0" text="Enter Evidence's ID:" textFill="#0d2c54">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  <TextField fx:id="EviID" layoutX="211.0" layoutY="16.0" onAction="#Remove" prefHeight="25.0" prefWidth="200.0" style="-fx-text-fill: #F5F5F5; -fx-background-color: #0D2C54; -fx-border-color: #6A1017; -fx-border-width: 3;">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </TextField>
               </children>
            </AnchorPane>
         </children>
      </AnchorPane>
   </center>
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="800.0" spacing="10.0" style="-fx-background-color: #0D2C54; -fx-padding: 5; -fx-border-color: #6A1017; -fx-border-width: 5;" BorderPane.alignment="CENTER">
         <children>
            <Label prefHeight="20.0" prefWidth="710.0" text="Crime Management System" textFill="WHITESMOKE">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <Button fx:id="minimzeBtn" mnemonicParsing="false" onAction="#titleBar" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #F5F5F5;" text="-" textFill="#0d2c54">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
            <Button fx:id="closeBtn" mnemonicParsing="false" onAction="#titleBar" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #6A1017;" text="X" textFill="WHITESMOKE">
               <font>
